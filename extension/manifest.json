{
  "manifest_version": 3,
  "name": "Prototype Map Recorder",
  "version": "1.0.0",
  "description": "Record prototype journeys with form data for prototype-map",
  "permissions": [
    "activeTab",
    "alarms",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "http://localhost/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
